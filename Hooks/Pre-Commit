#!/usr/bin/env bash
# Auto-detecting pre-commit hook: lint (staged files) + tests (full suite).
# Supports Python (ruff/flake8 + pytest/unittest) and Node (npm/pnpm).
#
# Bypass:
#   git commit --no-verify   (skips this hook entirely)
#   SKIP_LINT=1              (skips lint only)
#   SKIP_TESTS=1             (skips tests only)
#
# Per-repo override (first match wins, replaces global checks):
#   git config hooks.disableGlobal true       -> skip global, exit 0
#   .git/hooks/pre-commit.local (executable)  -> exec it instead of global
#   .githooks/pre-commit (executable)         -> exec it instead of global
#
# Designed to be installed globally via:
#   git config --global core.hooksPath <dir-containing-this-file>

set -euo pipefail

# ---------- Color output (only when stderr is a TTY) ----------
if [ -t 2 ] && command -v tput >/dev/null 2>&1 && [ "$(tput colors 2>/dev/null || echo 0)" -ge 8 ]; then
    C_RED=$(tput setaf 1); C_GREEN=$(tput setaf 2); C_YELLOW=$(tput setaf 3)
    C_BLUE=$(tput setaf 4); C_BOLD=$(tput bold); C_RESET=$(tput sgr0)
else
    C_RED=; C_GREEN=; C_YELLOW=; C_BLUE=; C_BOLD=; C_RESET=
fi

info() { printf '%s[pre-commit]%s %s\n' "$C_BLUE"   "$C_RESET" "$*" >&2; }
ok()   { printf '%s[pre-commit]%s %s\n' "$C_GREEN"  "$C_RESET" "$*" >&2; }
warn() { printf '%s[pre-commit]%s warn: %s\n' "$C_YELLOW" "$C_RESET" "$*" >&2; }
err()  { printf '%s[pre-commit]%s error: %s\n' "$C_RED" "$C_RESET" "$*" >&2; }

# ---------- Locate the repo ----------
REPO_ROOT=$(git rev-parse --show-toplevel)
GIT_DIR=$(git rev-parse --git-dir)
cd "$REPO_ROOT"

# ---------- Skip during merge / rebase / cherry-pick ----------
if [ -f "$GIT_DIR/MERGE_HEAD" ];        then info "merge in progress, skipping";       exit 0; fi
if [ -f "$GIT_DIR/CHERRY_PICK_HEAD" ];  then info "cherry-pick in progress, skipping"; exit 0; fi
if [ -d "$GIT_DIR/rebase-merge" ] || [ -d "$GIT_DIR/rebase-apply" ]; then
    info "rebase in progress, skipping"; exit 0
fi

# ---------- Per-repo override (first match wins, replaces global checks) ----------
if [ "$(git config --get hooks.disableGlobal 2>/dev/null || true)" = "true" ]; then
    info "hooks.disableGlobal=true, skipping global checks"
    exit 0
fi
for _candidate in "$REPO_ROOT/.git/hooks/pre-commit.local" "$REPO_ROOT/.githooks/pre-commit"; do
    if [ -x "$_candidate" ]; then
        info "delegating to per-repo hook: $_candidate"
        exec "$_candidate" "$@"
    fi
done
unset _candidate

# ---------- Detect initial commit (no HEAD yet) ----------
if git rev-parse --verify HEAD >/dev/null 2>&1; then HAS_HEAD=1; else HAS_HEAD=0; fi

# ---------- Read staged file list (null-separated; handles spaces/newlines) ----------
STAGED_FILES=()
while IFS= read -r -d '' f; do STAGED_FILES+=("$f"); done < <(
    git diff --cached --name-only -z --diff-filter=ACMR
)

if [ ${#STAGED_FILES[@]} -eq 0 ]; then
    info "no staged changes, skipping"
    exit 0
fi

# ---------- Stash unstaged changes for correctness ----------
# Without this, lint sees the working tree, not what's actually being committed.
STASHED=0
TIMER_PID=

need_stash() {
    [ "$HAS_HEAD" -eq 1 ] || return 1
    if ! git diff --quiet; then return 0; fi
    if [ -n "$(git ls-files --others --exclude-standard)" ]; then return 0; fi
    return 1
}

stop_timer() {
    if [ -n "$TIMER_PID" ]; then
        kill "$TIMER_PID" 2>/dev/null || true
        wait "$TIMER_PID" 2>/dev/null || true
        TIMER_PID=
    fi
}

cleanup() {
    local exit_code=$?
    trap - EXIT INT TERM
    stop_timer
    if [ "$STASHED" -eq 1 ]; then
        info "restoring unstaged changes"
        if ! git stash pop --index --quiet; then
            err "could not auto-restore stashed changes; recover with: git stash list"
            [ "$exit_code" -eq 0 ] && exit_code=1
        fi
    fi
    exit "$exit_code"
}

if need_stash; then
    info "stashing unstaged changes for accurate lint"
    if git stash push --keep-index --include-untracked --quiet -m "pre-commit-$$" 2>/dev/null; then
        STASHED=1
        trap cleanup EXIT INT TERM
    else
        warn "could not stash unstaged changes; linting working-tree content (may be inaccurate)"
    fi
fi

# ---------- Helpers ----------
filter_ext() {
    # Usage: filter_ext "py|pyi"  -> prints matching staged files that still exist
    local pattern="$1" f
    for f in "${STAGED_FILES[@]}"; do
        if [[ "$f" =~ \.($pattern)$ ]] && [ -f "$f" ]; then
            printf '%s\n' "$f"
        fi
    done
}

has_file() { [ -f "$1" ]; }

# Returns 0 if package.json defines a script with the given name.
pkg_has_script() {
    local name="$1"
    if command -v node >/dev/null 2>&1; then
        node -e "
            try { const s = (require('./package.json').scripts || {});
                  process.exit(s['$name'] && !/^echo \"Error: no test specified/.test(s['$name']) ? 0 : 1); }
            catch (e) { process.exit(1); }
        " 2>/dev/null
    else
        grep -Eq "\"$name\"[[:space:]]*:[[:space:]]*\"" package.json
    fi
}

FAILED=0
run_check() {
    # Usage: run_check "label" cmd args...
    local label="$1"; shift
    info "$label: ${C_BOLD}$*${C_RESET}"
    if "$@"; then
        ok "$label passed"
    else
        local rc=$?
        err "$label failed (exit $rc)"
        FAILED=1
    fi
}

start_timer() {
    (
        sleep 60
        printf '%s[pre-commit]%s tests >60s; bypass with %sgit commit --no-verify%s or %sSKIP_TESTS=1%s\n' \
            "$C_YELLOW" "$C_RESET" "$C_BOLD" "$C_RESET" "$C_BOLD" "$C_RESET" >&2
    ) &
    TIMER_PID=$!
}

# ---------- LINT ----------
if [ "${SKIP_LINT:-0}" = "1" ]; then
    warn "SKIP_LINT=1, skipping lint"
else
    # Python
    if has_file pyproject.toml || has_file requirements.txt || has_file setup.py || has_file setup.cfg; then
        PY_FILES=()
        while IFS= read -r f; do PY_FILES+=("$f"); done < <(filter_ext "py|pyi")
        if [ ${#PY_FILES[@]} -gt 0 ]; then
            if command -v ruff >/dev/null 2>&1; then
                run_check "ruff" ruff check "${PY_FILES[@]}"
            elif command -v flake8 >/dev/null 2>&1; then
                run_check "flake8" flake8 "${PY_FILES[@]}"
            else
                warn "Python project detected but neither 'ruff' nor 'flake8' installed; skipping Python lint"
            fi
        fi
    fi

    # Node
    if has_file package.json; then
        PM=
        if has_file pnpm-lock.yaml && command -v pnpm >/dev/null 2>&1; then
            PM=pnpm
        elif command -v npm >/dev/null 2>&1; then
            PM=npm
        fi
        if [ -n "$PM" ]; then
            if pkg_has_script lint; then
                run_check "$PM run lint" "$PM" run --silent lint
            else
                info "no 'lint' script in package.json, skipping Node lint"
            fi
        else
            warn "package.json found but no npm/pnpm available; skipping Node lint"
        fi
    fi
fi

# ---------- TESTS ----------
if [ "${SKIP_TESTS:-0}" = "1" ]; then
    warn "SKIP_TESTS=1, skipping tests"
else
    # Python
    if has_file pyproject.toml || has_file setup.py || has_file setup.cfg || has_file tox.ini || [ -d tests ] || [ -d test ]; then
        if command -v pytest >/dev/null 2>&1; then
            start_timer; run_check "pytest" pytest; stop_timer
        elif [ -d tests ] || [ -d test ]; then
            PY=python3; command -v python3 >/dev/null 2>&1 || PY=python
            if command -v "$PY" >/dev/null 2>&1; then
                start_timer; run_check "unittest" "$PY" -m unittest discover; stop_timer
            else
                warn "Python project detected but no python interpreter available; skipping tests"
            fi
        else
            warn "Python project detected but no pytest and no tests/ dir; skipping Python tests"
        fi
    fi

    # Node
    if has_file package.json; then
        PM=
        if has_file pnpm-lock.yaml && command -v pnpm >/dev/null 2>&1; then
            PM=pnpm
        elif command -v npm >/dev/null 2>&1; then
            PM=npm
        fi
        if [ -n "$PM" ] && pkg_has_script test; then
            start_timer; run_check "$PM test" "$PM" test --silent; stop_timer
        fi
    fi
fi

# ---------- Result ----------
if [ "$FAILED" -ne 0 ]; then
    err "pre-commit hook failed; bypass with --no-verify if intentional"
    exit 1
fi

ok "all checks passed"
exit 0
